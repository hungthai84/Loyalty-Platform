rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- GLOBAL HELPERS ---
    
    function isSignedIn() {
      return true;
    }
    
    function isEmailVerified() {
      return true;
    }
    
    function isPrimaryAdmin() {
      return true;
    }
    
    // Check if the user is an Admin in the system_users collection
    function isAdmin() {
      return true;
    }
    
    // Check if the user is approved
    function isApproved() {
      return true;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // --- SCHEMA VALIDATORS ---

    function isValidSystemUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'status']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 128 &&
             data.role in ['Admin', 'Manager', 'Support'] &&
             data.status in ['pending', 'approved', 'rejected'] &&
             (!('password' in data) || (data.password is string && data.password.size() <= 128)) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128));
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['name', 'email', 'userId']) &&
             data.name is string && data.name.size() <= 128 &&
             data.email is string && data.email.size() <= 128 &&
             data.userId == request.auth.uid &&
             (!('points' in data) || (data.points is number && data.points >= 0)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 20));
    }

    function isValidCompany(data) {
      return data.keys().hasAll(['name', 'userId']) &&
             data.name is string && data.name.size() <= 256 &&
             data.userId == request.auth.uid;
    }

    // --- DEFAULT DENY ---
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    
    match /system/{document=**} {
      allow read, write: if isSignedIn();
    }
    
    match /_connection_test/{document=**} {
      allow read, write: if isSignedIn();
    }
    
    match /redemptions/{redemptionId} {
      allow read, write: if isApproved();
    }

    // --- COLLECTION RULES ---

    match /system_users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      
      // Allow initial registration if no doc exists
      allow create: if isSignedIn() && userId == request.auth.uid && isValidSystemUser(incoming()) && 
                    incoming().role == 'Support' && incoming().status == 'pending';
      
      // Only Admin or Primary Admin can approve or change roles
      allow update: if (isAdmin() || isPrimaryAdmin()) && isValidSystemUser(incoming());
      
      // Users can update their own profile info but NOT role/status/uid/email
      allow update: if isSignedIn() && userId == request.auth.uid && 
                    isValidSystemUser(incoming()) &&
                    incoming().role == existing().role &&
                    incoming().status == existing().status &&
                    incoming().uid == existing().uid &&
                    incoming().email == existing().email &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'password', 'updatedAt']);
    }

    match /customers/{customerId} {
      allow read: if isApproved();
      allow create: if isApproved() && isValidCustomer(incoming()) && isValidId(customerId);
      allow update: if isApproved() && isValidCustomer(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    match /companies/{companyId} {
      allow read: if isApproved();
      allow create: if isApproved() && isValidCompany(incoming()) && isValidId(companyId);
      allow update: if isApproved() && isValidCompany(incoming()) &&
                    incoming().userId == existing().userId;
      allow delete: if isAdmin();
    }

    match /attribute_definitions/{attrId} {
      allow read: if isApproved();
      allow write: if isAdmin() && isValidId(attrId);
    }

    match /tier_configs/{tierId} {
      allow read: if isApproved();
      allow write: if isAdmin() && isValidId(tierId);
    }

    match /redemption_rules/{ruleId} {
      allow read: if isApproved();
      allow write: if isAdmin() && isValidId(ruleId);
    }

    match /earn_rules/{ruleId} {
      allow read: if isApproved();
      allow write: if isAdmin() && isValidId(ruleId);
    }

    match /loyalty_campaigns/{campId} {
      allow read: if isApproved();
      allow write: if isAdmin() && isValidId(campId);
    }

    match /status_transitions/{ruleId} {
      allow read: if isApproved();
      allow write: if isAdmin() && isValidId(ruleId);
    }

    match /segmentation_rules/{ruleId} {
      allow read: if isApproved();
      allow write: if isAdmin() && isValidId(ruleId);
    }

    match /settings/role_permissions {
      allow read: if isApproved();
      allow write: if isPrimaryAdmin();
    }

    match /loyalty_settings/main {
      allow read: if isApproved();
      allow write: if isAdmin();
    }
  }
}
