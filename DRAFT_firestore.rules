rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitive Definitions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // 2. Validation Blueprints
    function isValidCustomer(data) {
      return data.keys().hasAll(['name', 'userId', 'createdAt', 'updatedAt'])
        && data.keys().size() >= 4
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && (data.email == null || (data.email is string && data.email.size() <= 200))
        && (data.phone == null || (data.phone is string && data.phone.size() <= 50))
        && data.userId == request.auth.uid
        && data.createdAt == request.time
        && data.updatedAt == request.time
        && (data.get('customFields', {}) is map);
    }

    function isValidAttributeDefinition(data) {
      return data.keys().hasAll(['label', 'key', 'type', 'userId', 'createdAt'])
        && data.keys().size() == 5
        && data.label is string && data.label.size() > 0 && data.label.size() <= 100
        && data.key is string && data.key.size() > 0 && data.key.size() <= 100
        && data.type in ['text', 'number', 'date', 'boolean']
        && data.userId == request.auth.uid
        && data.createdAt == request.time;
    }

    // 3. Resource Matches
    match /users/{userId}/customers/{customerId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(customerId) && isValidCustomer(incoming());
      allow update: if isOwner(userId) && (
        // Action: Standard Update
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'phone', 'customFields', 'updatedAt'])
        && incoming().updatedAt == request.time
        && (incoming().name is string && incoming().name.size() <= 200)
        && (incoming().get('customFields', {}) is map)
      );
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/attributeDefinitions/{attributeId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(attributeId) && isValidAttributeDefinition(incoming());
      allow delete: if isOwner(userId);
      // Updates are typically not allowed for attribute definitions to prevent schema breakage, but can be added if needed.
    }
  }
}
