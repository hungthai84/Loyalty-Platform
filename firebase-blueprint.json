{
  "entities": {
    "SystemUser": {
      "title": "System User",
      "description": "Represents an internal CRM user/staff with role-based access.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Auth UID" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Manager", "Support"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "password": { "type": "string" },
        "isLocal": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "status"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A VIP customer record in the CRM.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "facebook": { "type": "string" },
        "zalo": { "type": "string" },
        "linkedin": { "type": "string" },
        "instagram": { "type": "string" },
        "tiktok": { "type": "string" },
        "points": { "type": "number" },
        "activityStatus": { "type": "string", "enum": ["active", "inactive", "churn_risk"] },
        "companyId": { "type": "string" },
        "userId": { "type": "string", "description": "ID of the staff who created/manages this record" },
        "customFields": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "userId"]
    },
    "Company": {
      "title": "Company",
      "description": "A company for the catalog.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "websiteUrl": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "address", "phone", "userId"]
    },
    "CatalogProduct": {
      "title": "Catalog Product",
      "description": "A product belonging to a company.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "website": { "type": "string" },
        "companyId": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "description", "companyId", "userId"]
    },
    "AttributeDefinition": {
      "title": "Attribute Definition",
      "description": "Definition of a custom field for customers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "key": { "type": "string" },
        "type": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["label", "key", "type", "userId"]
    },
    "TierConfig": {
      "title": "Tier Configuration",
      "description": "Loyalty tier threshold and benefits definition.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "threshold": { "type": "number" },
        "color": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "threshold", "userId"]
    },
    "RedemptionRule": {
      "title": "Redemption Rule",
      "description": "Points-to-Reward redemption rule.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "pointsRequired": { "type": "number" },
        "rewardValue": { "type": "number" },
        "rewardType": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "pointsRequired", "rewardType", "userId"]
    },
    "EarnRule": {
      "title": "Earn Rule",
      "description": "Rules for earning points.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "points": { "type": "number" },
        "isActive": { "type": "boolean" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "points", "userId"]
    },
    "LoyaltyCampaign": {
      "title": "Loyalty Campaign",
      "description": "Automated marketing campaign config.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "isActive": { "type": "boolean" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "userId"]
    },
    "SegmentationRule": {
      "title": "Segmentation Rule",
      "description": "Rules for automated customer tagging.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "tag": { "type": "string" },
        "color": { "type": "string" },
        "criteriaType": { "type": "string" },
        "operator": { "type": "string" },
        "value": { "type": "number" },
        "isActive": { "type": "boolean" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "tag", "criteriaType", "operator", "value", "userId"]
    },
    "RolePermissions": {
      "title": "Role Permissions",
      "description": "RBAC permission matrix for roles.",
      "type": "object",
      "properties": {
        "permissions": { "type": "array" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["permissions"]
    },
    "LoyaltySettings": {
      "title": "Loyalty Settings",
      "description": "Global loyalty parameters.",
      "type": "object",
      "properties": {
        "inactiveThresholdDays": { "type": "number" },
        "churnThresholdDays": { "type": "number" },
        "autoApplyStatus": { "type": "boolean" },
        "userId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId"]
    }
  },
  "firestore": {
    "/system_users/{userId}": {
      "schema": "SystemUser",
      "description": "Application staff users."
    },
    "/companies/{companyId}": {
      "schema": "Company",
      "description": "Catalog companies."
    },
    "/catalog_products/{productId}": {
      "schema": "CatalogProduct",
      "description": "Catalog products."
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "VIP database."
    },
    "/attribute_definitions/{attrId}": {
      "schema": "AttributeDefinition",
      "description": "Custom field definitions."
    },
    "/tier_configs/{tierId}": {
      "schema": "TierConfig",
      "description": "Member tiers."
    },
    "/redemption_rules/{ruleId}": {
      "schema": "RedemptionRule",
      "description": "Reward gifts."
    },
    "/earn_rules/{ruleId}": {
      "schema": "EarnRule",
      "description": "Earning points logic."
    },
    "/loyalty_campaigns/{campId}": {
      "schema": "LoyaltyCampaign",
      "description": "Automated marketing campaigns."
    },
    "/segmentation_rules/{ruleId}": {
      "schema": "SegmentationRule",
      "description": "Customer segmentation logic."
    },
    "/settings/role_permissions": {
      "schema": "RolePermissions",
      "description": "Role-permission matrix."
    },
    "/loyalty_settings/main": {
      "schema": "LoyaltySettings",
      "description": "Primary loyalty global settings."
    }
  }
}
